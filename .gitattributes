# Default: detect text vs binary, normalize to LF on commit.
* text=auto eol=lf

# PowerShell stays CRLF in the working tree (Windows-native tooling).
*.ps1 text eol=crlf
*.psm1 text eol=crlf
*.psd1 text eol=crlf

# Explicit binary so git never line-end-converts these.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.gz binary
